# Переменные окружения для Telegram бота
# ВАЖНО: Не коммитьте этот файл в Git!

# Токен вашего Telegram бота (получите у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ваш Telegram Chat ID (узнайте у @userinfobot)
ADMIN_CHAT_ID=your_chat_id_here

# Токен бота MAX (используйте Vercel environment variables для продакшна)
MAX_BOT_TOKEN=your_max_bot_token_here
# Chat ID администратора в MAX (число)
MAX_ADMIN_CHAT_ID=282124260
# (Опционально) базовый URL API MAX, если отличается от https://api.max.ru
MAX_API_URL=https://api.max.ru
